# Create a new directory and enter it
function mkd() {
  mkdir -p "$@" && cd "$_";
}

# Change working directory to the top-most Finder window location
function cdf() { # short for `cdfinder`
  cd "$(osascript -e 'tell app "Finder" to POSIX path of (insertion location as alias)')";
}

# Keep awake
function nosleep() {
  pmset noidle;
}

# Determine size of a file or total size of a directory
function fs() {
  if du -b /dev/null > /dev/null 2>&1; then
    local arg=-sbh;
  else
    local arg=-sh;
  fi
  if [[ -n "$@" ]]; then
    du $arg -- "$@";
  else
    du $arg .[^.]* *;
  fi;
}

# Use Git’s colored diff when available
hash git &>/dev/null;
if [ $? -eq 0 ]; then
  function diff() {
    git diff --no-index --color-words "$@";
  }
fi;

# Create a data URL from a file
function dataurl() {
  local mimeType=$(file -b --mime-type "$1");
  if [[ $mimeType == text/* ]]; then
    mimeType="${mimeType};charset=utf-8";
  fi
  echo "data:${mimeType};base64,$(openssl base64 -in "$1" | tr -d '\n')";
}

# Run `dig` and display the most useful info
function digga() {
  dig +nocmd "$1" any +multiline +noall +answer;
}

# UTF-8-encode a string of Unicode symbols
function escape() {
  printf "\\\x%s" $(printf "$@" | xxd -p -c1 -u);
  # print a newline unless we’re piping the output to another program
  if [ -t 1 ]; then
    echo ""; # newline
  fi;
}

# Decode \x{ABCD}-style Unicode escape sequences
function unidecode() {
  perl -e "binmode(STDOUT, ':utf8'); print \"$@\"";
  # print a newline unless we’re piping the output to another program
  if [ -t 1 ]; then
    echo ""; # newline
  fi;
}

# Get a character’s Unicode code point
function codepoint() {
  perl -e "use utf8; print sprintf('U+%04X', ord(\"$@\"))";
  # print a newline unless we’re piping the output to another program
  if [ -t 1 ]; then
    echo ""; # newline
  fi;
}

# `vs` with no arguments opens the current directory in Visual Studio Code, otherwise
# opens the given location
function vs() {
  if [ $# -eq 0 ]; then
    code .;
  else
    code "$@";
  fi;
}

# `z` with no arguments opens the current directory in Zed, otherwise
# opens the given location
function z() {
  if [ $# -eq 0 ]; then
    zed .;
  else
    zed "$@";
  fi;
}

# `v` with no arguments opens the current directory in Vim, otherwise opens the
# given location
function v() {
  if [ $# -eq 0 ]; then
    vim .;
  else
    vim "$@";
  fi;
}

# `o` with no arguments opens the current directory, otherwise opens the given
# location
function o() {
  if [ $# -eq 0 ]; then
    open .;
  else
    open "$@";
  fi;
}

# `tre` is a shorthand for `tree` with hidden files and color enabled, ignoring
# the `.git` directory, listing directories first. The output gets piped into
# `less` with options to preserve color and line numbers, unless the output is
# small enough for one screen.
function tre() {
  tree -aC -I '.git|node_modules|bower_components' --dirsfirst "$@" | less -FRNX;
}

# Toggles dark mode
function dark() {
  osascript -e 'tell application "System Events" to tell appearance preferences to set dark mode to not dark mode'
}

# Fuzzy-pick a system timezone and set it
function tz() {
  sudo -v || return 1
  local picked
  picked=$(sudo systemsetup -listtimezones 2>/dev/null \
    | tail -n +2 \
    | sed 's/^[[:space:]]*//' \
    | fzf --prompt='timezone> ') || return
  [ -n "$picked" ] && sudo systemsetup -settimezone "$picked" 2>/dev/null
}

# Ping google.com and notify on connection state changes (up/unstable/down).
# State is derived from a rolling window of the last N pings:
#   - all succeed       → up
#   - all fail          → down
#   - >= loss threshold → unstable
# Live TUI shows stats; notifications use terminal-notifier with a group so
# new notifications replace old and all are cleared on exit. Falls back to
# osascript (which can't be removed) if terminal-notifier isn't installed.
function connection-monitor() {
  # Without TYPESET_SILENT, re-declaring an existing local (e.g. `local var`
  # in a loop) makes zsh echo the assignment — which leaks into the TUI.
  # NO_XTRACE/NO_VERBOSE silence any ambient shell tracing. LOCAL_OPTIONS
  # scopes all these to this function only (zsh).
  [ -n "$ZSH_VERSION" ] && setopt LOCAL_OPTIONS TYPESET_SILENT NO_XTRACE NO_VERBOSE
  [ -n "$BASH_VERSION" ] && { set +x; set +v; } 2>/dev/null

  local host="google.com"
  local window=10
  local unstable_loss_pct=30
  local notify_group="connection-monitor"

  local has_tn=0
  command -v terminal-notifier &>/dev/null && has_tn=1

  local results="" confirmed_state="up" loss_pct=0
  local total_ok=0 total_fail=0 last_latency="—"
  local events=""
  local state_started monitor_started
  state_started=$(date +%s)
  monitor_started=$state_started

  local stop=0
  trap 'stop=1' INT

  local esc=$'\033'
  local reset="${esc}[0m" dim="${esc}[2m" bold="${esc}[1m"
  local red="${esc}[31m" green="${esc}[32m" yellow="${esc}[33m" cyan="${esc}[36m"

  tput civis 2>/dev/null
  printf '%s' "${esc}[2J${esc}[H"

  while [ $stop -eq 0 ]; do
    local ping_output ok
    ping_output=$(command ping -c 1 -t 2 "$host" </dev/null 2>/dev/null)
    if [ $? -eq 0 ]; then
      ok=1
      total_ok=$((total_ok + 1))
      last_latency="$(printf '%s' "$ping_output" | grep -oE 'time=[0-9.]+' | head -1 | cut -d= -f2) ms"
    else
      ok=0
      total_fail=$((total_fail + 1))
      last_latency="timeout"
    fi

    results="${results}${ok}"
    [ ${#results} -gt $window ] && results="${results: -$window}"

    if [ ${#results} -ge $window ]; then
      local zeros="${results//[^0]/}"
      local fails=${#zeros}
      loss_pct=$(( (fails * 100) / window ))

      local new_state
      if [ $fails -eq 0 ]; then
        new_state="up"
      elif [ $fails -eq $window ]; then
        new_state="down"
      elif [ $loss_pct -ge $unstable_loss_pct ]; then
        new_state="unstable"
      else
        new_state="$confirmed_state"
      fi

      if [ "$new_state" != "$confirmed_state" ]; then
        local msg sound
        case "$new_state" in
          up)       msg="Connection STABLE";                       sound="Glass" ;;
          down)     msg="Connection DOWN";                         sound="Basso" ;;
          unstable) msg="Connection UNSTABLE (${loss_pct}% loss)"; sound="Funk"  ;;
        esac
        if [ $has_tn -eq 1 ]; then
          terminal-notifier -title "Connection Monitor" -message "$msg" \
            -sound "$sound" -group "$notify_group" &>/dev/null
        else
          osascript -e "display notification \"$msg\" with title \"Connection Monitor\" sound name \"$sound\"" &>/dev/null
        fi
        events="$(printf '  [%s] %s\n%s' "$(date '+%H:%M:%S')" "$msg" "$events" | head -n 5)"
        confirmed_state="$new_state"
        state_started=$(date +%s)
      fi
    fi

    # ---- render ----
    local now total success_pct=100 state_dur total_dur
    now=$(date +%s)
    total=$((total_ok + total_fail))
    [ $total -gt 0 ] && success_pct=$(( (total_ok * 100) / total ))
    state_dur=$(printf '%02d:%02d' $(( (now - state_started) / 60 )) $(( (now - state_started) % 60 )))
    total_dur=$(printf '%02d:%02d' $(( (now - monitor_started) / 60 )) $(( (now - monitor_started) % 60 )))

    local color label
    case "$confirmed_state" in
      up)       color="$green";  label="STABLE" ;;
      unstable) color="$yellow"; label="UNSTABLE" ;;
      down)     color="$red";    label="DOWN" ;;
    esac

    local spark="" i ch
    for ((i=0; i<${#results}; i++)); do
      ch="${results:$i:1}"
      if [ "$ch" = "1" ]; then spark="${spark}${green}▇${reset}"
      else spark="${spark}${red}▁${reset}"; fi
    done
    local p=$(( window - ${#results} ))
    while [ $p -gt 0 ]; do spark="${spark}${dim}·${reset}"; p=$((p - 1)); done

    printf '%s' "${esc}[H"
    printf '  %sConnection Monitor%s   %s●%s %s%s%s\n\n' "$bold" "$reset" "$color" "$reset" "$bold$color" "$label" "$reset"
    printf '  %sHost%s        %s\n'         "$dim" "$reset" "$host"
    printf '  %sIn state%s    %s\n'         "$dim" "$reset" "$state_dur"
    printf '  %sMonitoring%s  %s\n\n'       "$dim" "$reset" "$total_dur"
    printf '  %sPings%s       %s%d ok%s / %s%d fail%s   (%s%% success)\n' \
      "$dim" "$reset" "$green" "$total_ok" "$reset" "$red" "$total_fail" "$reset" "$success_pct"
    printf '  %sLast ping%s   %s\n'         "$dim" "$reset" "$last_latency"
    printf '  %sWindow%s      %s  %d%% loss\n\n' "$dim" "$reset" "$spark" "$loss_pct"
    printf '  %sRecent events%s\n'          "$dim" "$reset"
    if [ -n "$events" ]; then
      printf '%s\n' "$events"
    else
      printf '    %s(none yet)%s\n' "$dim" "$reset"
    fi
    printf '\n  %sCtrl+C to stop%s' "$dim" "$reset"
    printf '%s' "${esc}[J"

    sleep 1
  done

  # cleanup
  tput cnorm 2>/dev/null
  printf '%s' "${esc}[2J${esc}[H"
  [ $has_tn -eq 1 ] && terminal-notifier -remove "$notify_group" &>/dev/null
  trap - INT

  printf '%sConnection Monitor stopped%s\n' "$bold" "$reset"
  printf '  Monitored:   %s\n' "$total_dur"
  printf '  Final state: %s%s%s\n' "$color" "$label" "$reset"
  printf '  Pings:       %d ok / %d fail  (%d%% success)\n' "$total_ok" "$total_fail" "$success_pct"
}

# Dependabot merge all PRs
function dependabot-merge-all() {
  for i in $(gh pr list --limit 100 --json number --json author --jq '.[] | select(.author.login == "app/dependabot") | .number'); do
    echo "Merging PR #$i"
    gh pr review $i --approve
    gh pr merge $i --merge --delete-branch

    # Capture the exit status immediately after the merge command
    merge_status=$?

    if [ $merge_status -ne 0 ]; then
      gh pr comment $i --body "@dependabot recreate"
      echo "Failed to merge PR #$i, will recreate"
    else
      echo "Merged PR #$i"
    fi
  done
}

# Docker machine
machine () {
    DOCKER_MACHINE_NAME="$1"
    if [ -z "$DOCKER_MACHINE_NAME" ]
        then DOCKER_MACHINE_NAME=default
    fi
    eval `docker-machine env $DOCKER_MACHINE_NAME`
}
create-machine () {
    DOCKER_MACHINE_NAME="$1"
    if [ -z "$DOCKER_MACHINE_NAME" ]
        then DOCKER_MACHINE_NAME=default
    fi

    if [ ! -f ~/.ssh/config ]; then
      touch ~/.ssh/config
      chmod 600 ~/.ssh/config
    fi

    if ! grep -q "StrictHostKeyChecking no" ~/.ssh/config; then
      echo "MATCH exec \"test -d ~/.docker/machine/machines/%h\"
        StrictHostKeyChecking no
        UserKnownHostsFile /dev/null
        IdentityFile ~/.docker/machine/machines/%h/id_rsa
        User root" >> ~/.ssh/config
    fi

    sudo -v # login now for later use
    docker-machine create $DOCKER_MACHINE_NAME
    eval `docker-machine env $DOCKER_MACHINE_NAME`
    sudo hosts remove --force $DOCKER_MACHINE_NAME
    sudo hosts add `docker-machine ip $DOCKER_MACHINE_NAME` \
        $DOCKER_MACHINE_NAME "docker machine host"
}
sync-machine () {
    if [ ! -z "$1" ]; then machine "$1"; fi
    ssh $DOCKER_MACHINE_NAME "mkdir -p $PWD && chmod 777 $PWD"
    # add additional commands for your setup
    mutagen sync create --sync-mode two-way-resolved \
        --label "machine=$DOCKER_MACHINE_NAME" \
        --name "$(basename $PWD)" \
        --ignore-vcs \
        $PWD $DOCKER_MACHINE_NAME:$PWD
}
drop-machine () {
    if [ ! -z "$1" ]; then machine "$1"; fi
    sudo -v # login now for later use
    docker-machine rm $DOCKER_MACHINE_NAME
    mutagen sync terminate --label-selector "machine=$DOCKER_MACHINE_NAME"
    sudo hosts remove --force $DOCKER_MACHINE_NAME
}
create-machine-here () {
    create-machine "$1"
    sync-machine
}
